############
# Arquivos de sobrescrita do docker compose para sobrepor o docker-compose.yml.
# O COMPOSE_FILE nativo do docker compose: lista separada por dois pontos, começando pela base.
# Gerencie com: ./run.sh config add|remove <name>
#
# Exemplos:
#   COMPOSE_FILE=docker-compose.yml
#   COMPOSE_FILE=docker-compose.yml:docker-compose.pg17.yml
#
############
COMPOSE_FILE=docker-compose.yml


############

JWT_JWKS={"keys":[{"kty":"EC","kid":"f7fb6470-9eb6-49e6-a09d-b185b17d846a","use":"sig","key_ops":["verify"],"alg":"ES256","ext":true,"crv":"P-256","x":"qfXvDB1L2DMHQ1RS_yE9hZ10yW8W2ZZ-A082KIhD0yU","y":"uU9SUFtqo-KVN0ZISEbCTiIaAQbt6vVl78bY8Qc3SzU"},{"kty":"oct","k":"VUxqUGJ5Y0ZYR0JOQnlDaDBTVDRkVVdkL2YzRWljdXhtaUZISDFGdg","alg":"HS256"}]}

# Acesso ao painel
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=23950cdb75779ed6b7a7cab3ed112ef9

# Chave de criptografia para proteger as comunicações do Realtime e do Supavisor.
# (Precisa ter pelo menos 64 caracteres; gere com: openssl rand -base64 48)
SECRET_KEY_BASE=2wSe2loMB1y8Wb0dv9jeR9oo8gDUsRnYX80q5X6ApMhjDdaroJw1hN94LkXNghv6

# Chave de criptografia usada pelo Realtime para campos sensíveis no schema `_realtime`.
# (Precisa ter exatamente 16 caracteres; gere com: `openssl rand -hex 8`)
REALTIME_DB_ENC_KEY=c1dd3841f075d5f2

# Chave de criptografia usada pelo Supavisor para armazenar configuração criptografada.
# (Precisa ter exatamente 32 caracteres; gere com: openssl rand -hex 16)
VAULT_ENC_KEY=ff7589d9da6f0626f746c4e36b51fdd4

# Chave de criptografia para proteger strings de conexão usadas pelo Studio contra postgres-meta.
# (Precisa ter pelo menos 32 caracteres; gere com: openssl rand -base64 24)
PG_META_CRYPTO_KEY=54LcvkSG2m4aQLZLsi4+3qYo81GW7E75

# Token de API para ingestão de logs usado pelo Logflare e Vector.
# (Precisa ter pelo menos 32 caracteres; gere com: openssl rand -base64 24)
LOGFLARE_PUBLIC_ACCESS_TOKEN=1wx/6bCcru+KsmhnT0Wsj+Vk1IQ7jopx
# Token de API usado para operações de gestão do Logflare. Nunca expor no lado do cliente.
# (Precisa ter pelo menos 32 caracteres; gere com: openssl rand -base64 24)
LOGFLARE_PRIVATE_ACCESS_TOKEN=k2mdpbD1C89F9L/EEFjDdpyYQy4FgDKV

# ID da chave de acesso (tipo usuário) para acessar o endpoint do protocolo S3 no Storage.
# (Gere com: openssl rand -hex 16)
S3_PROTOCOL_ACCESS_KEY_ID=e15b05e752b66712dbf3651d4bcb6e07
# Chave secreta (tipo senha) usada com S3_PROTOCOL_ACCESS_KEY_ID.
# (Gere com: openssl rand -hex 32)
S3_PROTOCOL_ACCESS_KEY_SECRET=1a6a0cfa80168cec5ccd7b9777163224d5347f817408a8a750278b7acf141498


############
# URLs - Configure os hostnames abaixo para refletirem seu domínio real
############

# Acesso ao painel e à API REST
SUPABASE_PUBLIC_URL=http://alugmacoisa.autoniza.com.br

# URL externa completa do serviço de Auth, usada para construir callbacks OAuth,
# endpoints SAML e links de e-mail
API_EXTERNAL_URL=http://alugmacoisa.autoniza.com.br/auth/v1

# Consulte também a seção de Auth abaixo para configuração de Site URL e URLs de redirecionamento


############
# Banco de dados - configuração do Postgres
############

# Usando o usuário padrão (postgres)
POSTGRES_HOST=db
POSTGRES_DB=postgres

# A configuração padrão inclui o Supavisor expondo POSTGRES_PORT
# O Postgres usa POSTGRES_PORT dentro do container
# Documentação:
# https://supabase.com/docs/guides/self-hosting/docker#accessing-postgres-through-supavisor
POSTGRES_PORT=5432


############
# Supavisor - pool de banco de dados
############

# O Supavisor expõe POSTGRES_PORT e POOLER_PROXY_PORT_TRANSACTION,
# POSTGRES_PORT é usado para pool em modo de sessão
#
# Porta para usar para conexões de pooling em modo transacional
POOLER_PROXY_PORT_TRANSACTION=6543

# Número máximo de conexões PostgreSQL que o Supavisor abre por pool
POOLER_DEFAULT_POOL_SIZE=20

# Número máximo de conexões de cliente que o Supavisor aceita
POOLER_MAX_CLIENT_CONN=100

# Identificador único do tenant do Supavisor
# Documentação:
# https://supabase.com/docs/guides/self-hosting/docker#accessing-postgres
POOLER_TENANT_ID=your-tenant-id

# Tamanho do pool para armazenamento interno de metadados usado pelo Supavisor
# Isso é separado das conexões de cliente e é usado apenas pelo próprio Supavisor
POOLER_DB_POOL_SIZE=5


############
# Studio - configuração do painel
############

STUDIO_DEFAULT_ORGANIZATION=Autoniza
STUDIO_DEFAULT_PROJECT=WACRM

# Adicione sua chave da API OpenAI para ativar o assistente de IA
OPENAI_API_KEY=sk-proj-xxxxxxxx


############
# Auth - configuração do servidor de autenticação
############

## Configurações gerais

# Equivalente às opções de "Site URL" e "Redirect URLs" da plataforma
# Documentação: https://supabase.com/docs/guides/auth/redirect-urls
SITE_URL=http://alugmacoisa.autoniza.com.br
ADDITIONAL_REDIRECT_URLS=

JWT_EXPIRY=3600
DISABLE_SIGNUP=false

## Configuração do mailer
MAILER_URLPATHS_CONFIRMATION="/auth/v1/verify"
MAILER_URLPATHS_INVITE="/auth/v1/verify"
MAILER_URLPATHS_RECOVERY="/auth/v1/verify"
MAILER_URLPATHS_EMAIL_CHANGE="/auth/v1/verify"

## Autenticação por e-mail
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=fake_mail_user
SMTP_PASS=fake_mail_password
SMTP_SENDER_NAME=fake_sender
ENABLE_ANONYMOUS_USERS=false

## Autenticação por telefone
ENABLE_PHONE_SIGNUP=true
ENABLE_PHONE_AUTOCONFIRM=true

## Provedores OAuth / login social

# Descomente e preencha os provedores que deseja ativar.
# Você também deve descomentar as linhas correspondentes GOTRUE_EXTERNAL_* em docker-compose.yml
# Documentação: https://supabase.com/docs/guides/self-hosting/self-hosted-oauth
# GOOGLE_ENABLED=false
# GOOGLE_CLIENT_ID=
# GOOGLE_SECRET=

# GITHUB_ENABLED=false
# GITHUB_CLIENT_ID=
# GITHUB_SECRET=

# AZURE_ENABLED=false
# AZURE_CLIENT_ID=
# AZURE_SECRET=

# Configuração do provedor de telefone / SMS
# Descomente para configurar a entrega de SMS para autenticação por telefone e MFA.
# Você também deve descomentar as linhas correspondentes GOTRUE_SMS_* em docker-compose.yml
# Documentação: https://supabase.com/docs/guides/self-hosting/self-hosted-phone-mfa
# SMS_PROVIDER=twilio
# SMS_OTP_EXP=60
# SMS_OTP_LENGTH=6
# SMS_MAX_FREQUENCY=60s
# SMS_TEMPLATE=Seu código é {{ .Code }}

# SMS_TWILIO_ACCOUNT_SID=
# SMS_TWILIO_AUTH_TOKEN=
# SMS_TWILIO_MESSAGE_SERVICE_SID=

# OTP de teste: associe números de telefone a códigos OTP fixos para desenvolvimento
# Formato: phone1:code1,phone2:code2
# SMS_TEST_OTP=

# Autenticação multifator (MFA)
# Descomente para alterar os padrões do MFA.
# Você também deve descomentar as linhas correspondentes GOTRUE_MFA_* em docker-compose.yml

# Autenticador do app (TOTP) - ativado por padrão
# MFA_TOTP_ENROLL_ENABLED=true
# MFA_TOTP_VERIFY_ENABLED=true

# MFA por telefone - desativado por padrão (opcional)
# MFA_PHONE_ENROLL_ENABLED=false
# MFA_PHONE_VERIFY_ENABLED=false

# Número máximo de fatores MFA que um usuário pode cadastrar
# MFA_MAX_ENROLLED_FACTORS=10

## SAML SSO

# Você também deve descomentar as linhas correspondentes GOTRUE_* em docker-compose.yml
# Documentação: https://supabase.com/docs/guides/self-hosting/self-hosted-saml-sso

# SAML_ENABLED=true
# SAML_PRIVATE_KEY=<sua-chave-privada-em-base64>

# Opcional: aceitar asserções SAML criptografadas de IdPs (padrão: false)
# SAML_ALLOW_ENCRYPTED_ASSERTIONS=false

# Opcional: quanto tempo os tokens relay state permanecem válidos (padrão: 2m0s)
# SAML_RELAY_STATE_VALIDITY_PERIOD=2m0s

# Opcional: sobrescrever o ID da entidade SAML / URL base do ACS
# Padrão: API_EXTERNAL_URL se não estiver definido
# SAML_EXTERNAL_URL=https://supabase.example.com:8000/auth/v1

# Opcional: limite de taxa no endpoint ACS (solicitações por segundo, padrão: 15)
# SAML_RATE_LIMIT_ASSERTION=15


############
# Storage - configuração do Storage
############

# Verifique as chaves S3_PROTOCOL_ACCESS_KEY_ID/SECRET acima e
# consulte a documentação em:
# https://supabase.com/docs/guides/self-hosting/self-hosted-s3
# para aprender a configurar o endpoint do protocolo S3

# Bucket S3 ao usar o backend S3, nome do diretório ao usar 'file'
GLOBAL_S3_BUCKET=stub

# Usado para configuração do endpoint do protocolo S3
REGION=stub

# Usado pelo MinIO quando adicionado via:
# docker compose -f docker-compose.yml -f docker-compose.s3.yml up -d
MINIO_ROOT_USER=supa-storage
# Senha de administrador raiz do servidor RustFS ou MinIO.
# (Precisa ter 8+ caracteres; gere com: openssl rand -hex 16)
MINIO_ROOT_PASSWORD=bb985d33dbdde1050c88a16753a059f2

# Equivalente a project_ref conforme descrito aqui:
# https://supabase.com/docs/guides/storage/s3/authentication#session-token
STORAGE_TENANT_ID=stub


############
# Functions - configuração para Edge functions
############

# Documentação:
# https://supabase.com/docs/guides/self-hosting/self-hosted-functions

# OBSERVAÇÃO: VERIFY_JWT se aplica a todas as functions
FUNCTIONS_VERIFY_JWT=false


############
# API - configuração para PostgREST
############

# Schemas do Postgres expostos via API REST
PGRST_DB_SCHEMAS=public,graphql_public

# Número máximo de linhas retornadas por uma solicitação
PGRST_DB_MAX_ROWS=1000

# Schemas extras adicionados ao search_path de cada requisição
PGRST_DB_EXTRA_SEARCH_PATH=public


############
# Logs e Analytics
############

## Coleta e roteamento de logs do Vector

# Localização do socket do Docker - obrigatória para o funcionamento adequado do Vector
DOCKER_SOCKET_LOCATION=/var/run/docker.sock
# Para Podman, use o seguinte:
# DOCKER_SOCKET_LOCATION=/run/podman/podman.sock

## Analytics (Logflare)

# Verifique a configuração de token LOGFLARE_* acima.
# Se o Logflare precisar ser exposto externamente - configure com segurança!

# Detalhes do projeto Google Cloud
# Documentação:
# https://supabase.com/docs/reference/self-hosting-analytics/introduction
GOOGLE_PROJECT_ID=GOOGLE_PROJECT_ID
GOOGLE_PROJECT_NUMBER=GOOGLE_PROJECT_NUMBER


############
# API gateway
############

# Variáveis de configuração do Kong
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

# Usado internamente pelo API gateway - NÃO use em código cliente ou servidor.
# JWT "API key" pré-assinada ES256 para o papel anon.
ANON_KEY_ASYMMETRIC=eyJhbGciOiJFUzI1NiIsInR5cCI6IkpXVCIsImtpZCI6ImY3ZmI2NDcwLTllYjYtNDllNi1hMDlkLWIxODViMTdkODQ2YSJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlIiwiaWF0IjoxNzgzODk2MDU0LCJleHAiOjE5NDE1NzYwNTR9.UMwWR8HqVy_4SJ1WiJeqDOtZDX8utSgvUduDxhmMRRtwrgDXIE9c3XFJa5zZPan0XGQacWfFXKjMdbavLaMueA
# JWT "API key" pré-assinada ES256 para service_role.
SERVICE_ROLE_KEY_ASYMMETRIC=eyJhbGciOiJFUzI1NiIsInR5cCI6IkpXVCIsImtpZCI6ImY3ZmI2NDcwLTllYjYtNDllNi1hMDlkLWIxODViMTdkODQ2YSJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UiLCJpYXQiOjE3ODM4OTYwNTQsImV4cCI6MTk0MTU3NjA1NH0.Jgp5-AzxtFzNJAIhE1mMXckZcgBGYSOfJ8omFLIMe2RbZUXXrKoizMvFy6TnI0jmHPgosXOXrj49glY5PbzNPQ


############
# imgproxy
############

# Ative o suporte a webp
IMGPROXY_AUTO_WEBP=true


############
# Proxy TLS - Caddy ou Nginx opcional com reverse proxy e Let's Encrypt
############

# Documentação:
# https://supabase.com/docs/guides/self-hosting/self-hosted-proxy-https

# Uso:
# docker compose -f docker-compose.yml -f docker-compose.caddy.yml up -d
# docker compose -f docker-compose.yml -f docker-compose.nginx.yml up -d

# Nome de domínio do proxy (deve apontar para o seu servidor)
PROXY_DOMAIN=your-domain.example.com

# E-mail para notificações do certificado Let's Encrypt (somente nginx; o Caddy usa PROXY_DOMAIN).
# Isso deve ser um e-mail válido, não um placeholder (caso contrário o Certbot pode falhar ao iniciar).
CERTBOT_EMAIL=admin@example.com

# Array JSON de JWKs de assinatura (privada EC + simétrica legacy).
# Usado pelo Auth.
JWT_KEYS=[{"kty":"EC","kid":"f7fb6470-9eb6-49e6-a09d-b185b17d846a","use":"sig","key_ops":["sign","verify"],"alg":"ES256","ext":true,"crv":"P-256","x":"qfXvDB1L2DMHQ1RS_yE9hZ10yW8W2ZZ-A082KIhD0yU","y":"uU9SUFtqo-KVN0ZISEbCTiIaAQbt6vVl78bY8Qc3SzU","d":"Y7T0rPX4rVs-lvN-OX_WRlIC7cuXpAuOQkMArVuNT9c"},{"kty":"oct","k":"VUxqUGJ5Y0ZYR0JOQnlDaDBTVDRkVVdkL2YzRWljdXhtaUZISDFGdg","alg":"HS256"}]
# JWKS para verificação de token (pública EC + simétrica legacy).

#
# VOCÊ PRECISA ALTERAR TODOS OS VALORES PADRÃO ABAIXO ANTES DE INICIAR
# OS CONTAINERS PELA PRIMEIRA VEZ!
#
# Documentação:
# https://supabase.com/docs/guides/self-hosting/docker#configuring-and-securing-supabase
#
# Para gerar segredos e chaves de API:
# 1. sh utils/generate-keys.sh
# 2. sh utils/add-new-auth-keys.sh
#
############

# Postgres
POSTGRES_PASSWORD=cc86d65c7c44443af510c15aa2e8d1f5

# Chave simétrica legacy HS256
JWT_SECRET=ULjPbycFXGBNByCh0ST4dUWd/f3EicuxmiFHH1Fv
# Chaves legacy da API (JWTs assinados com HS256)
